# Copy this file to ".env" and fill in real values.
# AP_ENCRYPTION_KEY must be exactly 32 hex chars:  openssl rand -hex 16
# AP_JWT_SECRET can be longer/random:              openssl rand -hex 32

ACTIVEPIECES_VERSION=latest

# Database password. AP_POSTGRES_PASSWORD and POSTGRES_PASSWORD MUST be
# identical (one is read by Activepieces, the other by Postgres on first init).
AP_POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_PASSWORD=__CHANGE_ME__

# Encrypts stored connections/secrets. EXACTLY 32 hex characters. Set once.
AP_ENCRYPTION_KEY=__CHANGE_ME_32_HEX__

# Signs auth tokens. Long & random. Set once.
AP_JWT_SECRET=__CHANGE_ME__

# Canonical URL Activepieces is reached at (scheme + host + port, trailing /).
# Use your Tailscale MagicDNS name. Must match how you open it or login breaks.
AP_FRONTEND_URL=http://YOUR-HOST.your-tailnet.ts.net:8080/

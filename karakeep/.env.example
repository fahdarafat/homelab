# Copy this file to ".env" and fill in real values.
# Generate secrets with:  openssl rand -base64 36   (PowerShell alt: see README)
KARAKEEP_VERSION=release
DATA_DIR=/data
MEILI_ADDR=http://meilisearch:7700
MEILI_MASTER_KEY=__CHANGE_ME__

# Canonical URL Karakeep is reached at (must match how you open it, or login breaks).
# Use your Tailscale MagicDNS name (recommended) or LAN IP, with the port.
NEXTAUTH_URL=http://YOUR-HOST.your-tailnet.ts.net:3000
NEXTAUTH_SECRET=__CHANGE_ME__

# Optional: enables AI auto-tagging (also uncomment OPENAI_API_KEY in docker-compose.yml)
# OPENAI_API_KEY=sk-...

# Copy this file to ".env" and fill in real values.
# Generate the secret key with:  openssl rand -base64 64
# (PowerShell alt: [Convert]::ToBase64String((1..48 | % { Get-Random -Max 256 })) )

# Django secret. Long & random. Changing it later logs everyone out.
PAPERLESS_SECRET_KEY=__CHANGE_ME__

# Database password. PAPERLESS_DBPASS and POSTGRES_PASSWORD MUST be identical
# (one is read by Paperless, the other by Postgres on first init).
PAPERLESS_DBPASS=__CHANGE_ME__
POSTGRES_PASSWORD=__CHANGE_ME__

# Canonical URL Paperless is reached at (needed so it trusts the host on login
# / uploads). Use your Tailscale MagicDNS name with the port.
PAPERLESS_URL=http://YOUR-HOST.your-tailnet.ts.net:8000

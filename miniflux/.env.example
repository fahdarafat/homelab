# Miniflux secrets — copy to .env and fill in. NEVER commit the real .env.
#   Copy-Item miniflux\.env.example miniflux\.env

# Password for Miniflux's PostgreSQL database. Used by the postgres container AND
# embedded in DATABASE_URL below — the two MUST match.
POSTGRES_PASSWORD=__CHANGE_ME__

# Connection string Miniflux uses. Host is the postgres service name (miniflux-postgres);
# the password here must equal POSTGRES_PASSWORD above.
DATABASE_URL=postgres://miniflux:__CHANGE_ME__@miniflux-postgres/miniflux?sslmode=disable

# First-boot admin account (created because CREATE_ADMIN=1). Used to log in.
ADMIN_USERNAME=__CHANGE_ME__
ADMIN_PASSWORD=__CHANGE_ME__

# Canonical HTTPS URL — Miniflux bakes this in, so it must be the Tailscale HTTPS host
# or logins/redirects break. Replace the middle with your tailnet:
#   https://rss.<your-tailnet>.ts.net
BASE_URL=https://rss.__CHANGE_ME__.ts.net

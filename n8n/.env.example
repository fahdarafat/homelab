# Copy this file to ".env" and fill in real values.
# Generate secrets with:  openssl rand -hex 32
# (PowerShell alt: [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 })) )

N8N_VERSION=latest

# Database password. DB_POSTGRESDB_PASSWORD and POSTGRES_PASSWORD MUST be
# identical (one is read by n8n, the other by Postgres on first init).
DB_POSTGRESDB_PASSWORD=__CHANGE_ME__
POSTGRES_PASSWORD=__CHANGE_ME__

# Encrypts saved credentials. Changing it later makes existing credentials
# unreadable, so set once and keep it.
N8N_ENCRYPTION_KEY=__CHANGE_ME__

# Canonical host n8n is reached at (no scheme, no port). Use your Tailscale
# MagicDNS name. Must match how you open it or login/webhooks break.
N8N_HOST=YOUR-HOST.your-tailnet.ts.net

# Full base URL used to build webhook links (scheme + host + port + trailing /).
WEBHOOK_URL=http://YOUR-HOST.your-tailnet.ts.net:5678/

# --- SMS → Actual Budget pipeline ---
# actual-http-api base URL (internal docker network) and its x-api-key.
ACTUAL_API_URL=http://actual-http-api:5007
ACTUAL_API_KEY=changeme-same-as-actual-http-api-API_KEY
ACTUAL_BUDGET_SYNC_ID=changeme-actual-sync-id
# last-4 -> Actual account id map (JSON). Use YOUR real account ids.
SMS_ACCOUNT_MAP={"1234":"hsbc-cc-id","5678":"cib-acct-id","9012":"cib-debit-id"}
# Auto-import when confidence >= this; below routes to review.
SMS_CONF_THRESHOLD=0.8
# FX markup applied to converted non-EGP charges (0.03 = +3%).
SMS_FX_MARKUP=0.03
# OpenAI key for the GPT-4o mini parse call.
OPENAI_API_KEY=changeme-openai-key
# ntfy target for review notifications.
NTFY_URL=http://ntfy:80
NTFY_TOPIC=sms-actual
# Shared secret the ntfy Approve button must send to the sms-confirm webhook.
SMS_CONFIRM_SECRET=changeme-long-random

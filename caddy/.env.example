# Copy this file to ".env" and fill in real values.

# Your tailnet's DNS domain — the part AFTER the machine name in a MagicDNS
# hostname. Find it in the Tailscale admin console (DNS page) or run
# `tailscale status`; it looks like "tailXXXX.ts.net" or your custom name.
# Each app is then served at "<app>.<TS_NET>", e.g. memos.tailXXXX.ts.net.
TS_NET=your-tailnet.ts.net

# Tailscale auth key used to register the per-app nodes. Generate one in the
# admin console (Settings -> Keys -> Generate auth key). It MUST be:
#   - Reusable        (one key registers ~12 nodes here)
#   - Non-ephemeral   (matches `ephemeral false` in the Caddyfile)
# Optionally pre-approve/Tag it so the nodes don't need manual approval.
TS_AUTHKEY=tskey-auth-__CHANGE_ME__
